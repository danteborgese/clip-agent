# Supabase (server-side)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (browser client — Realtime + job history)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (moment detection + tagging)
OPENAI_API_KEY=

# Supabase Storage (clip uploads)
SUPABASE_CLIPS_BUCKET=clips

# Notion (clip page creation)
NOTION_TOKEN=
NOTION_CLIPS_DB_ID=

# YouTube Data API v3 (recommended — avoids bot detection for metadata)
